{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "online": {
      ".read":  "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "queue": {
      ".read":  "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
